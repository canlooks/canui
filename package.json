{
  "name": "@canlooks/can-ui",
  "version": "0.0.194",
  "author": "C.CanLiang <canlooks@gmail.com>",
  "description": "My ui framework",
  "license": "MIT",
  "keywords": [
    "ui framework"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/canlooks/canui",
  "repository": {
    "type": "git",
    "url": "https://github.com/canlooks/canui"
  },
  "bugs": {
    "url": "https://github.com/canlooks/canui/issues",
    "email": "canlooks@gmail.com"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./extensions/*": {
      "types": "./extensions/*/index.d.ts",
      "import": "./extensions/*/index.mjs",
      "require": "./extensions/*/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "npx shx rm -rf dist",
    "build": "tsc -m esnext --outDir dist/esm & tsc -m commonjs --outDir dist/cjs",
    "build:alias": "tsc-alias --outDir dist/esm",
    "rebuild": "npm run clean && npm run build && npm run build:alias",
    "dev": "vite -c test/vite.config.mts",
    "dev:ssr": "next dev test",
    "test:unit": "npx ts-node test/unit.ts"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.3.2",
    "@emotion/react": "^11.14.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@types/react-transition-group": "^4.4.12",
    "color": "^5.0.3",
    "dayjs": "^1.11.20",
    "react-transition-group": "^4.4.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.1",
    "@canlooks/react-router": "^2.0.6",
    "@canlooks/reactive": "^4.7.18",
    "@emotion/styled": "^11.14.1",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@mui/icons-material": "^9.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "mime": "^4.1.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
